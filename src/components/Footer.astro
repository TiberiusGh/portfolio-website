---
import { profile } from '../data/cv'
const year = new Date().getFullYear()
---

<footer>
  <p>
    © {year} {profile.name} ·
    <a href={profile.repoUrl} target="_blank" rel="noopener noreferrer">View source on GitHub</a>
  </p>
</footer>

<style>
  footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    text-align: center;
  }

  footer p {
    margin: 0;
  }
</style>
