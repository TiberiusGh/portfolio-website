---
import { contactLinks } from '../data/cv'
import Icon from './Icon.astro'
---

<section id="contact" class="section-measure">
  <h2 class="section-title">Contact</h2>
  <ul class="contact-list">
    {
      contactLinks.map((link) => (
        <li>
          <Icon name={link.icon} size={20} label={link.label} class="contact-icon" />
          <a href={link.href}>{link.href.replace(/^mailto:/, '')}</a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .contact-icon {
    flex-shrink: 0;
    color: var(--color-text);
  }
</style>
